class FairFaceDataset(Dataset):
    def __init__(self, hf_dataset, transform=None):
        self.data = hf_dataset; self.transform = transform
    def __len__(self): return len(self.data)
    def __getitem__(self, idx):
        s = self.data[idx]
        img = s["image"].convert("RGB")
        if self.transform: img = self.transform(img)
        return {
            "image" : img,
            "age"   : torch.tensor(s["age"],    dtype=torch.long),
            "gender": torch.tensor(s["gender"], dtype=torch.long),
            "race"  : torch.tensor(s["race"],   dtype=torch.long),
        }


def balanced_stratified_indices(n_total_target, age_labels, seed=42):
    
    rng        = np.random.RandomState(seed)
    age_labels = np.asarray(age_labels)
    classes    = np.unique(age_labels)
    n_classes  = len(classes)

    if n_total_target is None:
        return list(range(len(age_labels))), None

    n_per_class = n_total_target // n_classes
    selected = []
    actual_counts = {}
    for cls in classes:
        cls_idx = np.where(age_labels == cls)[0]
        n_take  = min(n_per_class, len(cls_idx))
        chosen  = rng.choice(cls_idx, size=n_take, replace=False)
        selected.extend(chosen.tolist())
        actual_counts[AGE_NAMES[cls]] = n_take

    rng.shuffle(selected)
    return selected, n_per_class


