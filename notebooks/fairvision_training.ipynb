class FocalLoss(nn.Module):
  
    def __init__(self, gamma=2.0, alpha=None, label_smoothing=0.1):
        super().__init__()
        self.gamma = gamma; self.alpha = alpha; self.ls = label_smoothing

    def forward(self, logits, targets):
        n = logits.size(1)
        if self.ls > 0:
            with torch.no_grad():
                smooth = torch.full_like(logits, self.ls / (n - 1))
                smooth.scatter_(1, targets.unsqueeze(1), 1.0 - self.ls)
            log_p   = F.log_softmax(logits, dim=1)
            ce_loss = -(smooth * log_p).sum(dim=1)
        else:
            log_p   = F.log_softmax(logits, dim=1)
            ce_loss = F.nll_loss(log_p, targets, reduction="none")

        probs   = torch.softmax(logits, dim=1)
        pt      = probs.gather(1, targets.unsqueeze(1)).squeeze(1)
        focal_w = (1.0 - pt) ** self.gamma

        if self.alpha is not None:
            alpha_t = self.alpha.to(logits.device)[targets]
            loss = alpha_t * focal_w * ce_loss
        else:
            loss = focal_w * ce_loss
        return loss.mean()


def mixup_batch(images, labels, num_classes, alpha=0.4):
    lam  = np.random.beta(alpha, alpha) if alpha > 0 else 1.0
    perm = torch.randperm(images.size(0), device=images.device)
    mixed_x = lam * images + (1 - lam) * images[perm]
    ya = F.one_hot(labels,       num_classes).float()
    yb = F.one_hot(labels[perm], num_classes).float()
    return mixed_x, lam * ya + (1 - lam) * yb


def focal_loss_soft(logits, soft_y, gamma=2.0, alpha=None):
    log_p = F.log_softmax(logits, dim=1)
    probs = torch.softmax(logits, dim=1)
    pt    = (probs * soft_y).sum(dim=1)
    fw    = (1.0 - pt) ** gamma
    ce    = -(soft_y * log_p).sum(dim=1)
    if alpha is not None:
        a_t = (alpha.to(logits.device) * soft_y).sum(dim=1)
        return (a_t * fw * ce).mean()
    return (fw * ce).mean()


