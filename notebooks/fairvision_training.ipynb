def save_checkpoint(path, epoch, model, optimizer, scheduler, scaler,
                    history, best_val_acc):
    torch.save({
        "epoch"           : epoch,
        "model_state_dict": model.state_dict(),
        "optimizer_state" : optimizer.state_dict(),
        "scheduler_state" : scheduler.state_dict() if scheduler else None,
        "scaler_state"    : scaler.state_dict()    if scaler    else None,
        "history"         : history,
        "best_val_acc"    : best_val_acc,
    }, path)


def load_checkpoint(path, model, optimizer=None, scheduler=None,
                    scaler=None, device="cpu"):
    if not os.path.exists(path):
        return 1, {"train_loss":[],"val_loss":[],"train_acc":[],"val_acc":[]}, 0.0
    ckpt = torch.load(path, map_location=device, weights_only=False)
    model.load_state_dict(ckpt["model_state_dict"])
    if optimizer and ckpt.get("optimizer_state"):
        optimizer.load_state_dict(ckpt["optimizer_state"])
    if scheduler and ckpt.get("scheduler_state"):
        scheduler.load_state_dict(ckpt["scheduler_state"])
    if scaler and ckpt.get("scaler_state"):
        scaler.load_state_dict(ckpt["scaler_state"])
    print(f"   Resumed epoch {ckpt['epoch']} | best val acc: {ckpt['best_val_acc']:.4f}")
    return ckpt["epoch"] + 1, ckpt["history"], ckpt["best_val_acc"]


def train_epoch(model, loader, optimizer, alpha_t, device,
                use_mixup=True, focal_gamma=2.0, scaler=None, scheduler=None):
    model.train()
    total_loss = total_correct = total = 0

    for batch in tqdm(loader, desc="  train", leave=False):
        imgs   = batch["image"].to(device, non_blocking=True)
        labels = batch["age"].to(device,   non_blocking=True)
        optimizer.zero_grad(set_to_none=True)

        use_mix = use_mixup and (np.random.rand() < 0.5)

        if use_mix:
            mixed_x, soft_y = mixup_batch(imgs, labels, NUM_CLASSES)
            ctx = torch.cuda.amp.autocast() if scaler else torch.no_grad().__class__()
            if scaler:
                with torch.cuda.amp.autocast():
                    logits = model(mixed_x)
                    loss   = focal_loss_soft(logits, soft_y, focal_gamma, alpha_t)
                scaler.scale(loss).backward()
                scaler.unscale_(optimizer)
                nn.utils.clip_grad_norm_(model.parameters(), 1.0)
                scaler.step(optimizer); scaler.update()
            else:
                logits = model(mixed_x)
                loss   = focal_loss_soft(logits, soft_y, focal_gamma, alpha_t)
                loss.backward()
                nn.utils.clip_grad_norm_(model.parameters(), 1.0)
                optimizer.step()
            with torch.no_grad():
                preds = model(imgs).argmax(1)
        else:
            crit = FocalLoss(gamma=focal_gamma, alpha=alpha_t, label_smoothing=0.1)
            if scaler:
                with torch.cuda.amp.autocast():
                    logits = model(imgs); loss = crit(logits, labels)
                scaler.scale(loss).backward()
                scaler.unscale_(optimizer)
                nn.utils.clip_grad_norm_(model.parameters(), 1.0)
                scaler.step(optimizer); scaler.update()
            else:
                logits = model(imgs); loss = crit(logits, labels)
                loss.backward()
                nn.utils.clip_grad_norm_(model.parameters(), 1.0)
                optimizer.step()
            preds = logits.argmax(1)

        if scheduler: scheduler.step()   

        total_loss    += loss.item() * imgs.size(0)
        total_correct += (preds == labels).sum().item()
        total         += imgs.size(0)

    return total_loss / total, total_correct / total


@torch.no_grad()
def eval_epoch(model, loader, device):
    model.eval()
    total_loss = total_correct = total = 0
    crit = nn.CrossEntropyLoss()
    all_p, all_l, all_g, all_r = [], [], [], []

    for batch in tqdm(loader, desc="  eval ", leave=False):
        imgs   = batch["image"].to(device, non_blocking=True)
        labels = batch["age"].to(device,   non_blocking=True)
        logits = model(imgs)
        loss   = crit(logits, labels)
        preds  = logits.argmax(1)

        total_loss    += loss.item() * imgs.size(0)
        total_correct += (preds == labels).sum().item()
        total         += imgs.size(0)
        all_p.extend(preds.cpu().numpy());  all_l.extend(labels.cpu().numpy())
        all_g.extend(batch["gender"].numpy()); all_r.extend(batch["race"].numpy())

    return (total_loss/total, total_correct/total,
            np.array(all_p), np.array(all_l), np.array(all_g), np.array(all_r))


@torch.no_grad()
def eval_with_tta(model, hf_dataset, device, batch_size=64):
    model.eval()
    n           = len(hf_dataset)
    all_probs   = np.zeros((n, NUM_CLASSES), dtype=np.float32)
    all_labels  = np.array(hf_dataset["age"],    dtype=np.int64)
    all_genders = np.array(hf_dataset["gender"], dtype=np.int64)
    all_races   = np.array(hf_dataset["race"],   dtype=np.int64)

    for t_idx, tfm in enumerate(tta_transforms):
        ds  = FairFaceDataset(hf_dataset, tfm)
        dl  = DataLoader(ds, batch_size=batch_size, shuffle=False,
                         num_workers=2, pin_memory=True)
        buf = []
        for batch in tqdm(dl, desc=f"  TTA {t_idx+1}/5", leave=False):
            buf.append(torch.softmax(model(batch["image"].to(device)), dim=1).cpu().numpy())
        all_probs += np.concatenate(buf, axis=0)

    all_probs /= len(tta_transforms)
    preds = all_probs.argmax(axis=1)
    return preds, all_labels, all_genders, all_races, accuracy_score(all_labels, preds)


def run_training(model, tr_loader, vl_loader, epochs, lr,
                 alpha_tensor=None, use_mixup=True, focal_gamma=2.0,
                 model_name="model", weight_decay=1e-4, resume=True):

    optimizer = optim.AdamW(model.parameters(), lr=lr, weight_decay=weight_decay)

    scheduler = optim.lr_scheduler.OneCycleLR(
        optimizer,
        max_lr          = lr * 6,
        epochs          = epochs,
        steps_per_epoch = len(tr_loader),
        pct_start       = 0.3,
        anneal_strategy = "cos",
        div_factor      = 10,
        final_div_factor= 1e3,
    )

    _amp   = (DEVICE.type == "cuda")
    scaler = torch.cuda.amp.GradScaler(enabled=_amp)

    ckpt_path = os.path.join(CHECKPOINT_DIR, f"{model_name}_checkpoint.pt")
    best_path = os.path.join(CHECKPOINT_DIR, f"{model_name}_best.pth")

    start_epoch  = 1
    history      = {"train_loss":[],"val_loss":[],"train_acc":[],"val_acc":[]}
    best_val_acc = 0.0

    if resume and os.path.exists(ckpt_path):
        start_epoch, history, best_val_acc = load_checkpoint(
            ckpt_path, model, optimizer, scheduler, scaler, DEVICE)
    else:
        print(f"  Starting fresh — [{model_name}]")

    if start_epoch > epochs:
        print(f"   Already complete ({epochs} epochs). Loading best weights.")
        if os.path.exists(best_path):
            model.load_state_dict(torch.load(best_path, map_location=DEVICE, weights_only=True))
        return history

    for epoch in range(start_epoch, epochs + 1):
        tr_loss, tr_acc = train_epoch(
            model, tr_loader, optimizer, alpha_tensor, DEVICE,
            use_mixup=use_mixup, focal_gamma=focal_gamma,
            scaler=scaler, scheduler=scheduler,
        )
        vl_loss, vl_acc, *_ = eval_epoch(model, vl_loader, DEVICE)

        history["train_loss"].append(tr_loss)
        history["val_loss"].append(vl_loss)
        history["train_acc"].append(tr_acc)
        history["val_acc"].append(vl_acc)

        if vl_acc > best_val_acc:
            best_val_acc = vl_acc
            torch.save(model.state_dict(), best_path)

        save_checkpoint(ckpt_path, epoch, model, optimizer, scheduler,
                        scaler, history, best_val_acc)

        if epoch % 1 == 0 or epoch == 1:
            peak = torch.cuda.max_memory_allocated()/1e6 if _amp else 0
            if _amp: torch.cuda.reset_peak_memory_stats()
            lr_now = optimizer.param_groups[0]["lr"]
            print(f"  Ep {epoch:3d}/{epochs} "
                  f"| tr {tr_loss:.4f}/{tr_acc:.4f} "
                  f"| vl {vl_loss:.4f}/{vl_acc:.4f} "
                  f"| lr={lr_now:.5f}"
                  + (f" | {peak:.0f}MB" if _amp else "")
                  + " | ✓ saved to Drive")

    print(f"\n  Best val accuracy: {best_val_acc:.4f} ({best_val_acc*100:.2f}%)")
    model.load_state_dict(torch.load(best_path, map_location=DEVICE, weights_only=True))
    return history


